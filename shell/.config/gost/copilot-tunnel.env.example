# Copy to copilot-tunnel.env in this directory (gitignored), e.g.:
#   just copilot-gost-env-init
#   $EDITOR ~/.config/gost/copilot-tunnel.env
#   just copilot-gost-enable
#
# Neovim / COPILOT_HTTP_PROXY should match the HTTP listen URL, e.g.:
#   set -gx COPILOT_HTTP_PROXY 'http://127.0.0.1:2026'
#
# Passwords in URLs: use URL-encoding in GOST_FORWARD if needed.
GOST_LISTEN=http://127.0.0.1:8118
GOST_FORWARD=socks5://127.0.0.1:2027
