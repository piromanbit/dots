[
  {
    "battery": {
      "format": "{capacity} {icon}",
      "format-charging": "{capacity}  ",
      "format-full": "{capacity} {icon}",
      "format-icons": [
        " ",
        " ",
        " ",
        " ",
        " "
      ],
      "format-plugged": "{capacity}   ",
      "interval": 1,
      "states": {
        "critical": 5,
        "good": 90,
        "warning": 15
      }
    },
    "clock": {
      "format": " {:%a /%d /%m | %H:%M} ",
      "on-click": "galendae",
      "tooltip-format": "{:%B of %Y}"
    },
    "cpu": {
      "format": "{usage}% ",
      "interval": 1
    },
    "height": 17,
    "niri/workspaces": {
      "all-outputs": true,
      "disable-scroll": true,
      "disable-select-unfocused": true,
      "warp-on-scroll": false
    },
    "layer": "top",
    "margin-top": 5,
    "margin-bottom": 0,
    "margin-left": 100,
    "margin-right": 100,
    "memory": {
      "format": "{}%  ",
      "interval": 1
    },
    "modules-center": [],
    "modules-left": [
      "clock",
      "niri/workspaces"
    ],
    "modules-right": [
      "network",
      "cpu",
      "memory",
      "battery"
    ],
    "network": {
      "format-disconnected": "⚠",
      "format-wifi": " ",
      "on-click": "alacritty --class nmtui -e nmtui",
      "tooltip-format": "{essid}"
    },
    "output": [
      "eDP-1",
      "DP-1",
      "HDMI-A-1"
    ],
    "position": "top",
    "spacing": 0
  }
]
